{
  "name": "stock-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend API for stock tracking dashboard",
  "main": "dist/server.js",
  "scripts": {
    "start": "node server.js",
    "build": "tsc && node scripts/copy-runtime-assets.js",
    "postinstall": "npm rebuild sqlite3 --build-from-source || true",
    "dev": "nodemon --exec tsx server.ts",
    "worker": "node dist/alertWorker.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "collectCoverageFrom": [
      "models/**/*.{js,ts}",
      "services/**/*.{js,ts}",
      "controllers/**/*.{js,ts}",
      "middleware/**/*.{js,ts}",
      "utils/**/*.{js,ts}",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "keywords": [
    "stock",
    "dashboard",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.34.0",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.22.4",
    "winston": "^3.17.0",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "cookie-parser": "^1.4.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
